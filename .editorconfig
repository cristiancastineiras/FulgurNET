# EditorConfig is awesome: https://EditorConfig.org
# Top-most EditorConfig file.
root = true

# Default settings — applied everywhere unless overridden below.
[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 120

# C# specific — match the .NET 10 / dotnet format defaults.
[*.cs]
indent_size = 4
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
dotnet_diagnostic.IDE0073.severity = none
dotnet_style_namespace_match_folder = true:warning
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

# C# code files MUST have a final newline (matches insert_final_newline).
# This is the default but make it explicit for the FFI-generated file.
[NativeMethods.g.cs]
# Generated by csbindgen; never hand-edit. Loosen rules so a `cargo build`
# that regenerates this file doesn't pollute diffs.
generated_code = true
insert_final_newline = true

# Markdown — don't trim trailing whitespace, two trailing spaces mean
# "<br>" in CommonMark and trimming would silently break docs.
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# YAML
[*.{yml,yaml}]
indent_size = 2

# Rust
[*.rs]
indent_size = 4
max_line_length = 100
