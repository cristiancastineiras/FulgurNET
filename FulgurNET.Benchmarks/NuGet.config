<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Local NuGet config for the FulgurNET.Benchmarks project.

    Why this file exists:
      Some corporate dev environments ship a
      <PackageSourceMapping> in their global
      `%AppData%\NuGet\NuGet.config` that restricts which packages
      can come from `nuget.org`. Packages not in the allow-list
      (e.g. DinkToPdf, PuppeteerSharp) then fail to restore with
      NU1100 even though they exist on nuget.org.

    The local <packageSourceMapping> here REPLACES the global
    mapping for the working directory: a `*` pattern matches every
    package, so all dependencies — including benchmark-only ones —
    resolve from `nuget.org`.

    This file only affects the working directory and below — it
    does NOT leak to other repos on the machine.
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
